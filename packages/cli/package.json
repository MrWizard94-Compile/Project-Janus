{
  "name": "@aether/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "aether": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/bin.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aether/context": "workspace:*",
    "@aether/shared": "workspace:*",
    "@aether/task-queue": "workspace:*",
    "@aether/validation-kernel": "workspace:*",
    "@aether/workload-manager": "workspace:*",
    "@aether/worktree-manager": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
}